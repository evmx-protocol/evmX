# ============================================================================
#  EVMX - Environment Configuration
# ============================================================================
#
#  The 'npm run setup' command auto-creates this file with working defaults.
#  You only need to edit this for:
#    - Faster fork tests (replace public RPC with Alchemy/Infura)
#    - Mainnet deployment (add private key + BaseScan API key)
#
#  NEVER commit .env to version control!
# ============================================================================

# ── Fork Tests ──────────────────────────────────────────────────────────────
# Public RPC works but is rate-limited. For reliable tests use:
#   Alchemy: https://www.alchemy.com (free tier)
#   Infura:  https://infura.io (free tier)
BASE_RPC_URL=https://mainnet.base.org

# Base Mainnet contract addresses (do not change)
ROUTER_ADDRESS=0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24
WETH_ADDRESS=0x4200000000000000000000000000000000000006

# VRF: leave empty to auto-deploy local mock (recommended for testing)
# VRF_COORDINATOR=0xd5D517aBE5cF79B7e95eC98dB0f0277788aFF634
VRF_KEY_HASH=0xdc2f87677b01473c763cb0aee938ed3341512f6057324a584e5944e786144d70

# Pin fork to block 25M for deterministic replay
FORK_BLOCK_NUMBER=25000000

# ── Base Sepolia Testnet (hackathon / CRE) ────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Get test ETH: https://www.alchemy.com/faucets/base-sepolia
#
# Base Sepolia contract addresses (used by deploy-sepolia.js):
#   Router:          0x1689E7B1F10000AE47eBfE339a4f69dECd19F602
#   VRF Coordinator: 0x5C210eF41CD1a72de73bF76eC39637bB0d3d7BEE
#   VRF Key Hash:    0x9e1344a1247c8a1785d0a4681a27152bffdb43666ae5bf7d14d24a5efd44bf71
#   (These are hardcoded in deploy-sepolia.js, no need to set in .env)

# ── Deploy (npm run deploy:base or npm run deploy:sepolia) ────────────────
# DEPLOYER_PRIVATE_KEY=0x...
# MARKETING_WALLET=0x...
# VRF_SUBSCRIPTION_ID=12345
# BASESCAN_API_KEY=...

# ── Post-Deploy ─────────────────────────────────────────────────────────────
# EVMX_ADDRESS=0x...
# LIQUIDITY_ETH=1.0
# LIQUIDITY_TOKENS=50000000
